# ============================================================================
# TaskFlow — Distributed Task Queue System
# Environment Configuration Template
# ============================================================================
#
# SETUP:
#   1. Copy this file:  cp .env.example .env
#   2. Update values for your environment (especially SECRET_KEY, passwords)
#   3. Run validation:  python scripts/validate_env.py
#
# NEVER commit .env to version control — it is listed in .gitignore.
# Generate a secret key:  python -c "import secrets; print(secrets.token_hex(32))"
#
# ============================================================================

# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME=TaskFlow
APP_ENV=development                        # development | staging | production
DEBUG=True                                 # Set False in production
SECRET_KEY=change-me-to-a-random-64-char-string
VERSION=1.0.0

# ─── Server ──────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DASHBOARD_URL=http://localhost:3000        # Frontend origin (used for CORS)
API_BASE_URL=http://localhost:8000         # Public API URL

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://taskflow:taskflow@localhost:5432/taskflow
DATABASE_ECHO=False                        # True = log every SQL query (dev only)
DATABASE_POOL_SIZE=20                      # Connection pool size
DATABASE_MAX_OVERFLOW=40                   # Extra connections beyond pool size

# Credentials used by docker-compose to create the DB
DB_USER=taskflow
DB_PASSWORD=taskflow
DB_NAME=taskflow

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=                            # Set a strong password in production
REDIS_MAX_CONNECTIONS=50

# ─── JWT Authentication ─────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24                    # Access token lifetime (hours)
JWT_REFRESH_EXPIRATION_DAYS=30             # Refresh token lifetime (days)

# ─── Rate Limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# ─── Worker Configuration ───────────────────────────────────────────────────
WORKER_CAPACITY=5                          # Max concurrent tasks per worker
WORKER_TIMEOUT_SECONDS=300                 # Task execution timeout (seconds)
WORKER_MAX_RETRIES=5                       # Max retry attempts before DLQ
WORKER_RETRY_BACKOFF_SECONDS=2             # Exponential backoff base (seconds)
WORKER_HEARTBEAT_INTERVAL_SECONDS=10       # Heartbeat ping interval
WORKER_DEAD_TIMEOUT_SECONDS=30             # Mark worker dead after silence

# ─── Task Configuration ─────────────────────────────────────────────────────
TASK_DEFAULT_PRIORITY=5                    # 1 (lowest) — 10 (highest)
TASK_MIN_PRIORITY=1
TASK_MAX_PRIORITY=10

# ─── Email / SMTP ───────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@taskflow.io
SMTP_FROM_NAME=TaskFlow
SMTP_USE_TLS=True
SMTP_TIMEOUT_SECONDS=10
SMTP_CONNECTION_POOL_SIZE=5

# ─── Campaign Settings ──────────────────────────────────────────────────────
CAMPAIGN_DEFAULT_RATE_LIMIT=100            # Emails per minute default
CAMPAIGN_MAX_RATE_LIMIT=1000               # Hard cap on rate limit

# ─── Monitoring & Observability ──────────────────────────────────────────────
PROMETHEUS_ENABLED=True
PROMETHEUS_PORT=9090
LOG_LEVEL=INFO                             # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                            # json | text

TRACING_ENABLED=False
TRACING_ENDPOINT=                          # e.g. http://jaeger:4318/v1/traces
METRICS_ENABLED=True

# ─── Security ────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Feature Flags ──────────────────────────────────────────────────────────
ENABLE_CAMPAIGNS=True
ENABLE_SCHEDULING=True
ENABLE_DEPENDENCIES=True
ENABLE_DLQ=True
ENABLE_HEALTH_CHECK=True

# ─── Testing ────────────────────────────────────────────────────────────────
TESTING=False
TEST_DATABASE_URL=postgresql://taskflow:taskflow@localhost:5432/taskflow_test

# ─── Docker / Production ────────────────────────────────────────────────────
BACKEND_VERSION=latest
FRONTEND_VERSION=latest
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# ─── Grafana (monitoring stack) ──────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=taskflow-admin
GF_SERVER_ROOT_URL=http://localhost:3001
